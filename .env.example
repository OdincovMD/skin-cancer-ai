# Database (PostgreSQL) — имя сервиса из compose (внутри сети: postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=postgres

# Redis (queues, rate limiting, cache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_USER=
MINIO_PASSWORD=
MINIO_URL=http://minio:9000

# App
DOMAIN=
HOST=
BACKEND_URL=/backend
ML_URL=http://ml:8000
DESCRIPTION_ENABLED=false
DESCRIPTION_SERVICE_URL=http://description_service:8000
DESCRIPTION_SERVICE_API_TOKEN=
DESCRIPTION_CALLBACK_API_TOKEN=

# ML memory management
MODEL_CACHE_MEMORY_LIMIT_MB=4608
MODEL_CACHE_IDLE_TTL_SECONDS=600
ISOLATED_RARE_MODEL_WORKERS=1

API_V1_RATE_LIMIT_PER_MINUTE=5

IMAGE_ACCESS_SIGNING_SECRET=
IMAGE_ACCESS_TOKEN_TTL_SEC=3600

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=240
JWT_REMEMBER_ME_EXPIRE_MINUTES=240

SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Skin Cancer AI
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
VERIFICATION_EMAIL_RESEND_COOLDOWN_SEC=120
PASSWORD_RESET_TOKEN_TTL_HOURS=1
PASSWORD_RESET_COOLDOWN_SEC=120
FRONTEND_PUBLIC_URL=http://localhost:90
