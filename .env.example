# Database (PostgreSQL) — имя сервиса из compose (внутри сети: postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=postgres

# Redis (queues, rate limiting, cache)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_USER=
MINIO_PASSWORD=
MINIO_URL=http://minio:9000

# App
DOMAIN=
HOST=
BACKEND_URL=/backend
ML_URL=http://ml:8000

IMAGE_ACCESS_SIGNING_SECRET=
IMAGE_ACCESS_TOKEN_TTL_SEC=3600

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Skin Cancer AI
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# Интервал между повторными письмами верификации (секунды)
VERIFICATION_EMAIL_RESEND_COOLDOWN_SEC=120
# URL, по которому пользователь открывает сайт в браузере (ссылка из письма верификации).
# Docker + NGINX из compose: порт 90 → http://localhost:90
# Прод: https://ваш-домен.ru
FRONTEND_PUBLIC_URL=http://localhost:90